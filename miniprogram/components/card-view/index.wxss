.card-view { display: flex; flex-direction: column; gap: 22rpx; }
.identity-card { min-height: 480rpx; position: relative; overflow: hidden; padding: 34rpx; color: #fff; background: linear-gradient(140deg,#17346c,#2f6ee6 67%,#69a7ff); border-radius: 38rpx; box-shadow: 0 24rpx 55rpx rgba(39,91,190,.24); }
.identity-grid { position:absolute;inset:0;opacity:.13;background-image:linear-gradient(rgba(255,255,255,.3) 1rpx,transparent 1rpx),linear-gradient(90deg,rgba(255,255,255,.3) 1rpx,transparent 1rpx);background-size:46rpx 46rpx;transform:rotate(-8deg) scale(1.15); }
.identity-top { position: relative; display: flex; align-items: flex-start; justify-content: space-between; }
.avatar-wrap { width: 132rpx; height: 132rpx; padding: 5rpx; background: rgba(255,255,255,.2); border-radius: 39rpx; }.avatar{width:100%;height:100%;border-radius:34rpx}.avatar-fallback{display:flex;align-items:center;justify-content:center;font-size:48rpx;font-weight:800}
.contact-action { display:flex;align-items:center;gap:4rpx;margin:0;padding:12rpx 16rpx;color:#285aa8;background:#fff;border-radius:15rpx;font-size:20rpx;font-weight:700;line-height:1.2 }.contact-action text{font-size:29rpx}
.person-name { position:relative;display:block;margin-top:25rpx;font-size:48rpx;font-weight:900;letter-spacing:1rpx }.person-title{position:relative;display:block;margin-top:7rpx;color:#e0ebff;font-size:27rpx;font-weight:700}.person-company{position:relative;display:block;margin-top:10rpx;color:#c7d9f8;font-size:22rpx}
.contact-lines { position:relative;display:flex;flex-direction:column;gap:7rpx;margin-top:25rpx;padding-top:22rpx;border-top:1rpx solid rgba(255,255,255,.22);color:#e1eaff;font-size:22rpx }
.content-card { padding: 30rpx; background: #fff; border: 1rpx solid #e7ecf3; border-radius: 31rpx; box-shadow: 0 8rpx 26rpx rgba(38,56,88,.04); }.content-title{font-size:31rpx;font-weight:900}.content-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:22rpx}.content-head>text:last-child{max-width:360rpx;color:#98a2b2;font-size:21rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.content-head button{margin:0;padding:8rpx 15rpx;color:#3478f6;background:#edf4ff;border-radius:13rpx;font-size:20rpx;line-height:1.3}
.address-card{display:flex;flex-direction:column;gap:15rpx}.address-line{padding-top:15rpx;color:#65738a;border-top:1rpx solid #edf0f5;font-size:23rpx;line-height:1.6}.intro-copy{display:block;margin-top:18rpx;color:#5f6e83;font-size:25rpx;line-height:1.85}
.company-video{width:100%;height:340rpx;background:linear-gradient(135deg,#18346d,#3478f6);border-radius:23rpx;overflow:hidden}
.news-row{width:100%;display:grid;grid-template-columns:46rpx 1fr 26rpx;align-items:center;gap:12rpx;margin:0;padding:20rpx 0;text-align:left;background:transparent;border-bottom:1rpx solid #edf0f5;border-radius:0;line-height:1.4}.news-row:last-child{border-bottom:0}.news-index{width:42rpx;height:42rpx;display:flex;align-items:center;justify-content:center;color:#3478f6;background:#edf4ff;border-radius:13rpx;font-size:20rpx;font-weight:800}.news-title{font-size:25rpx;font-weight:700}.news-arrow{color:#a6afbc;font-size:35rpx}
.company-intro-card{padding-bottom:15rpx}.company-intro-image{width:100%;display:block;border-radius:20rpx;background:#f2f5f9}
