.enterprise-page{padding-bottom:60rpx}.editor-title{display:flex;align-items:center;justify-content:space-between}.editor-title button{margin:0 0 22rpx;padding:10rpx 16rpx;color:#3478f6;background:#edf4ff;border-radius:14rpx;font-size:21rpx;line-height:1.4}.media-actions{display:grid;grid-template-columns:1fr 1fr;gap:13rpx}.media-actions button{margin:0;padding:18rpx;color:#3478f6;background:#edf4ff;border:1rpx solid #d9e7ff;border-radius:17rpx;font-size:21rpx}.media-tip,.sort-tip{display:block;margin-top:14rpx;color:#919cad;font-size:20rpx;line-height:1.55}.poster-preview{width:100%;height:280rpx;margin-top:16rpx;border-radius:21rpx}.news-list{display:flex;flex-direction:column;gap:14rpx;margin-top:18rpx}.news-editor{display:grid;grid-template-columns:48rpx 1fr 48rpx;align-items:center;gap:10rpx;padding:16rpx;background:#f6f8fb;border:1rpx solid #e7ebf1;border-radius:20rpx;transition:.15s}.news-editor.dragging{opacity:.7;transform:scale(.98);border-color:#3478f6}.drag-handle{height:100%;display:flex;align-items:center;justify-content:center;color:#8a98ac;font-size:32rpx}.news-editor>view{display:flex;flex-direction:column;gap:10rpx}.news-editor input{height:66rpx;padding:0 17rpx;background:#fff;border:1rpx solid #e2e7ee;border-radius:14rpx;font-size:22rpx}.news-editor>button{width:44rpx;height:44rpx;margin:0;padding:0;display:flex;align-items:center;justify-content:center;color:#d15a55;background:#fff0ef;border-radius:13rpx;line-height:1}
.pdf-row{display:grid;grid-template-columns:72rpx 1fr auto;align-items:center;gap:15rpx;padding:19rpx;background:#f4f7fb;border-radius:20rpx}.pdf-icon{width:70rpx;height:70rpx;display:flex;align-items:center;justify-content:center;color:#fff;background:#ef5a55;border-radius:20rpx;font-size:19rpx;font-weight:900}.pdf-row>view{display:flex;flex-direction:column;gap:5rpx;min-width:0}.pdf-row>view text:first-child{font-size:22rpx;font-weight:800;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.pdf-row>view text:last-child{color:#929dac;font-size:18rpx}.pdf-row button{margin:0;padding:11rpx 15rpx;color:#3478f6;background:#fff;border-radius:14rpx;font-size:20rpx;line-height:1.3}.intro-preview{width:100%;margin-top:18rpx;border-radius:20rpx}
.preview-layer{position:fixed;z-index:200;inset:0;display:flex;align-items:flex-end;background:rgba(13,22,40,.48)}.preview-sheet{width:100%;height:94vh;display:flex;flex-direction:column;background:#f4f6fa;border-radius:38rpx 38rpx 0 0;overflow:hidden}.preview-head{height:100rpx;display:grid;grid-template-columns:180rpx 1fr 180rpx;align-items:center;padding:0 20rpx;background:#fff;border-bottom:1rpx solid #e6ebf1}.preview-head text{text-align:center;font-size:30rpx;font-weight:900}.preview-head button{margin:0;padding:15rpx;color:#3478f6;background:transparent;font-size:22rpx;line-height:1.2}.preview-head button:last-child{text-align:right;font-weight:800}.preview-body{flex:1;height:0;padding:22rpx}.preview-note{margin-bottom:18rpx;padding:19rpx;color:#41618e;background:#eaf2ff;border-radius:18rpx;font-size:20rpx;text-align:center}
