.public-page{min-height:100vh;padding:24rpx 24rpx 60rpx;background:#f4f6fa}.public-head{display:flex;align-items:center;justify-content:space-between;margin:4rpx 5rpx 22rpx}.public-head>view{display:flex;flex-direction:column}.public-head>view text:first-child{font-size:31rpx;font-weight:900}.public-head>view text:last-child{color:#8793a5;font-size:19rpx}.public-head button{margin:0;padding:13rpx 20rpx;color:#fff;background:#3478f6;border-radius:17rpx;font-size:21rpx;font-weight:800;line-height:1.3}.public-foot{display:block;margin-top:30rpx;color:#9aa4b3;text-align:center;font-size:19rpx}
