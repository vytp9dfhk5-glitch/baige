<view class="page-shell notifications-page">
  <view class="notice-intro"><text>消息通知</text><text>审核结果、拒绝原因和名片到期提醒会显示在这里</text></view>
  <view wx:if="{{!notifications.length}}" class="section-card empty-state"><view class="empty-icon">♢</view><text class="empty-title">暂无新消息</text></view>
  <view wx:else class="notice-list"><view wx:for="{{notifications}}" wx:key="id" class="notice-item {{item.tone}}"><text class="notice-icon">{{item.tone === 'success' ? '✓' : item.tone === 'danger' ? '!' : '◷'}}</text><view><text>{{item.title}}</text><text>{{item.detail}}</text><text>{{item.timeText}}</text></view></view></view>
</view>
