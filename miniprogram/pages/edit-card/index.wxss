.edit-page{padding-bottom:70rpx}.avatar-editor{display:flex;align-items:center;gap:26rpx}.current-avatar{width:142rpx;height:142rpx;flex:none;padding:5rpx;background:#edf2fa;border-radius:40rpx}.current-avatar image,.current-avatar text{width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:#fff;border-radius:35rpx;font-size:48rpx;font-weight:900}.avatar-options{flex:1}.default-avatars{display:grid;grid-template-columns:repeat(6,1fr);gap:8rpx}.default-avatars button{width:50rpx;height:50rpx;margin:0;padding:0;display:flex;align-items:center;justify-content:center;color:#fff;border:3rpx solid #fff;border-radius:16rpx;box-shadow:0 2rpx 8rpx rgba(30,50,80,.12);font-size:19rpx;font-weight:800}.upload-avatar{margin:16rpx 0 0;padding:10rpx 17rpx;color:#3478f6;background:#edf4ff;border-radius:14rpx;font-size:21rpx;line-height:1.4}.field-tip{display:block;margin:-12rpx 4rpx 22rpx;color:#9aa5b5;font-size:20rpx;line-height:1.55}
.address-input-row{display:flex;gap:12rpx}.address-input-row input{flex:1}.address-input-row button{width:110rpx;margin:0;display:flex;align-items:center;justify-content:center;color:#3478f6;background:#edf4ff;border-radius:20rpx;font-size:22rpx;font-weight:800}.address-suggestions{margin-top:10rpx;padding:8rpx;background:#f6f8fb;border-radius:18rpx}.address-suggestions button{width:100%;margin:0;padding:17rpx;text-align:left;background:transparent;border-bottom:1rpx solid #e6ebf2;border-radius:0;font-size:22rpx;line-height:1.5}.address-suggestions button:last-child{border-bottom:0}.selected-addresses{display:flex;flex-direction:column;gap:10rpx;margin-top:17rpx}.selected-addresses>view{display:flex;align-items:center;gap:10rpx;padding:15rpx 17rpx;color:#5f6f85;background:#f3f6fa;border-radius:16rpx;font-size:22rpx}.selected-addresses text{flex:1;line-height:1.5}.selected-addresses button{width:40rpx;height:40rpx;margin:0;padding:0;display:flex;align-items:center;justify-content:center;color:#8591a3;background:#fff;border-radius:12rpx;line-height:1}
.save-button{margin-top:10rpx}.save-tip{display:block;margin-top:15rpx;color:#9ba5b4;text-align:center;font-size:20rpx}
