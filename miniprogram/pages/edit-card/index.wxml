<view class="page-shell edit-page">
  <view class="form-section avatar-section">
    <text class="form-section-title">个人头像</text>
    <view class="avatar-editor">
      <view class="current-avatar">
        <image wx:if="{{form.avatar}}" src="{{form.avatar}}" mode="aspectFill"/>
        <text wx:else style="background:{{form.avatarColor}}">{{avatarInitial}}</text>
      </view>
      <view class="avatar-options">
        <view class="default-avatars">
          <button wx:for="{{avatarColors}}" wx:key="*this" style="background:{{item}}" data-color="{{item}}" bindtap="chooseDefaultAvatar">{{avatarInitial}}</button>
        </view>
        <button class="upload-avatar" bindtap="uploadAvatar">＋ 上传头像</button>
      </view>
    </view>
  </view>

  <view class="form-section">
    <text class="form-section-title">个人信息</text>
    <label class="field"><text class="field-label">姓名<text class="required">*</text></text><input class="field-input" value="{{form.name}}" data-field="name" bindinput="setField" placeholder="请输入姓名"/></label>
    <label class="field"><text class="field-label">职位<text class="required">*</text></text><input class="field-input" value="{{form.title}}" data-field="title" bindinput="setField" placeholder="请输入职位"/></label>
    <text wx:if="{{role === 'employee'}}" class="field-tip">修改员工清单中的默认职位会提交管理员审核；其他信息直接生效。</text>
    <label class="field"><text class="field-label">手机号</text><input class="field-input" type="number" maxlength="11" value="{{form.phone}}" data-field="phone" bindinput="setField" placeholder="用于名片公开展示"/></label>
    <text class="field-tip">这里修改的是名片展示手机号，不会改变登录手机号。</text>
    <label class="field"><text class="field-label">邮箱</text><input class="field-input" value="{{form.email}}" data-field="email" bindinput="setField" placeholder="请输入邮箱"/></label>
    <label class="field"><text class="field-label">微信号</text><input class="field-input" value="{{form.wechat}}" data-field="wechat" bindinput="setField" placeholder="请输入微信号"/></label>
    <label class="field"><text class="field-label">个人简介</text><textarea class="field-textarea" value="{{form.intro}}" data-field="intro" bindinput="setField" maxlength="800" placeholder="介绍你的经历、专业方向或个人观点"/></label>
  </view>

  <view class="form-section address-section">
    <text class="form-section-title">公司地址</text>
    <view class="address-input-row"><input class="field-input" value="{{addressQuery}}" bindinput="onAddressQuery" placeholder="输入关键词搜索或填写地址"/><button bindtap="addAddress">添加</button></view>
    <view wx:if="{{addressSuggestions.length}}" class="address-suggestions"><button wx:for="{{addressSuggestions}}" wx:key="*this" data-value="{{item}}" bindtap="chooseAddress">{{item}}</button></view>
    <view class="selected-addresses"><view wx:for="{{form.addresses}}" wx:key="*this"><text>{{item}}</text><button data-index="{{index}}" bindtap="removeAddress">×</button></view></view>
  </view>

  <button class="primary-button save-button" bindtap="save">保存并生成名片</button>
  <text class="save-tip">未填写的内容不会在名片中展示</text>
</view>
