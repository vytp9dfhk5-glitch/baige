.member-search{height:84rpx;display:flex;align-items:center;gap:13rpx;padding:0 20rpx;color:#7f8da2}.member-search input{flex:1;font-size:23rpx}.member-search button{width:44rpx;height:44rpx;margin:0;padding:0;display:flex;align-items:center;justify-content:center;color:#7e899a;background:#eef1f5;border-radius:13rpx;line-height:1}.member-meta{display:flex;justify-content:space-between;margin:13rpx 4rpx 18rpx;color:#8c98a9;font-size:19rpx}.member-list{overflow:hidden}.member-row{width:100%;display:grid;grid-template-columns:70rpx 1fr auto 25rpx;align-items:center;gap:15rpx;margin:0;padding:21rpx 20rpx;text-align:left;background:#fff;border-bottom:1rpx solid #edf0f4;border-radius:0;line-height:1.4}.member-row:last-child{border-bottom:0}.member-avatar{width:68rpx;height:68rpx;display:flex;align-items:center;justify-content:center;color:#3478f6;background:#eaf2ff;border-radius:22rpx;font-size:25rpx;font-weight:900}.member-avatar.admin{color:#7250d1;background:#efeaff}.member-avatar.broker{color:#a66b11;background:#fff2d9}.member-row>view{min-width:0;display:flex;flex-direction:column;gap:5rpx}.member-row>view>text:first-child{font-size:24rpx;font-weight:800}.member-row>view>text:not(:first-child){color:#7e8a9d;font-size:18rpx;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.role-chip{margin-left:8rpx;padding:4rpx 8rpx;color:#3478f6;background:#edf4ff;border-radius:8rpx;font-size:15rpx}.role-chip.admin{color:#7652d0;background:#f0ebff}.role-chip.broker{color:#a36b14;background:#fff1d8}.member-state{color:#cf514c;font-size:18rpx}.member-state.normal{color:#159b72}.row-arrow{color:#a0a9b6;font-size:34rpx}
.editor-layer{position:fixed;z-index:220;inset:0;display:flex;align-items:flex-end;background:rgba(13,22,40,.48)}.editor-sheet{width:100%;height:88vh;display:flex;flex-direction:column;background:#f5f7fa;border-radius:38rpx 38rpx 0 0;overflow:hidden}.editor-head{height:96rpx;display:flex;align-items:center;justify-content:space-between;padding:0 27rpx;background:#fff;border-bottom:1rpx solid #e7ebf1}.editor-head>text{font-size:30rpx;font-weight:900}.editor-head button{width:54rpx;height:54rpx;margin:0;padding:0;display:flex;align-items:center;justify-content:center;background:#f0f3f6;border-radius:17rpx;line-height:1}.editor-body{flex:1;height:0;padding:24rpx}.primary-tip{display:block;padding:15rpx;color:#866314;background:#fff5da;border-radius:15rpx;font-size:20rpx}.editor-actions{display:grid;grid-template-columns:1fr 1.5fr;gap:13rpx;padding:18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));background:#fff;border-top:1rpx solid #e4e9f0}.editor-actions button{margin:0;padding:21rpx;color:#65748b;background:#eef1f5;border-radius:19rpx;font-size:23rpx}.editor-actions button:last-child{color:#fff;background:#3478f6}
