.login-page { min-height: 100vh; padding: 92rpx 48rpx 50rpx; background: radial-gradient(circle at 85% 5%, #dceaff 0, transparent 30%), linear-gradient(180deg,#f8fbff,#edf3fb); }
.brand-mark { display: flex; align-items: baseline; gap: 5rpx; color: #23457b; font-weight: 900; }.brand-mark text:first-child{font-size:33rpx}.brand-mark text:last-child{font-size:22rpx;color:#3478f6}
.login-hero { display: flex; flex-direction: column; align-items: center; padding: 70rpx 0 50rpx; }.logo-orb{width:112rpx;height:112rpx;display:flex;align-items:center;justify-content:center;color:#fff;background:linear-gradient(145deg,#6da5ff,#2464dc);border-radius:36rpx;box-shadow:0 24rpx 48rpx rgba(52,120,246,.25);font-size:38rpx;font-weight:900}.login-title{margin-top:30rpx;font-size:42rpx;font-weight:900}.login-copy{margin-top:12rpx;color:#7d8da5;font-size:24rpx}
.login-panel { padding: 34rpx; background: rgba(255,255,255,.94); border: 1rpx solid #e4eaf2; border-radius: 34rpx; box-shadow: 0 24rpx 70rpx rgba(36,63,105,.10); }.panel-title{display:block;margin-bottom:24rpx;font-size:31rpx;font-weight:800}.login-input{height:94rpx;display:flex;align-items:center;gap:18rpx;padding:0 24rpx;margin-bottom:20rpx;background:#f7f9fc;border:1rpx solid #dfe6ef;border-radius:22rpx}.login-input>text{padding-right:18rpx;border-right:1rpx solid #dfe5ed;font-weight:700}.login-input input{flex:1}.code-input button{padding:0;color:#3478f6;background:transparent;font-size:24rpx;font-weight:700}.login-button{height:92rpx;display:flex;align-items:center;justify-content:center;margin-top:8rpx;color:#fff;background:linear-gradient(135deg,#245fcf,#3478f6);border-radius:23rpx;font-weight:800}.agreement{display:flex;align-items:center;justify-content:center;gap:10rpx;margin-top:22rpx;color:#8995a7;font-size:20rpx}.check{width:27rpx;height:27rpx;display:flex;align-items:center;justify-content:center;border:2rpx solid #b9c2cf;border-radius:8rpx}.check.checked{color:#fff;background:#3478f6;border-color:#3478f6}
.demo-accounts { margin-top: 34rpx; text-align: center; color: #8793a5; font-size: 22rpx; }.demo-accounts>view{display:flex;justify-content:center;gap:12rpx;margin:15rpx 0}.demo-accounts button{margin:0;padding:10rpx 18rpx;color:#416ea9;background:#fff;border:1rpx solid #dce5f1;border-radius:999rpx;font-size:21rpx}.demo-tip{font-size:19rpx;color:#a1aab8}
