.admin-page{padding-top:14rpx}.admin-hero{display:flex;flex-direction:column;gap:10rpx;padding:36rpx;color:#fff;background:linear-gradient(135deg,#1d3970,#3478f6 70%,#65a2ff);border-radius:38rpx;box-shadow:0 24rpx 48rpx rgba(45,96,197,.22)}.admin-hero text:first-child{font-size:39rpx;font-weight:900}.admin-hero text:last-child{color:#d4e3ff;font-size:22rpx}.section-title>view{display:flex;align-items:baseline;gap:13rpx}.section-title>view>text:first-child{font-size:30rpx;font-weight:900}.section-title>view>text:last-child{color:#9aa4b3;font-size:19rpx}
.enterprise-entry{width:100%;min-height:164rpx;display:grid;grid-template-columns:88rpx 1fr auto;align-items:center;gap:20rpx;margin:0;padding:27rpx;text-align:left;color:#fff;background:linear-gradient(135deg,#245fcf,#3478f6 72%,#68a5ff);border-radius:34rpx;box-shadow:0 20rpx 42rpx rgba(45,101,210,.2)}.entry-icon{width:88rpx;height:88rpx;display:flex;align-items:center;justify-content:center;background:rgba(255,255,255,.16);border:1rpx solid rgba(255,255,255,.25);border-radius:28rpx;font-size:37rpx}.enterprise-entry>view{display:flex;flex-direction:column;gap:8rpx}.enterprise-entry>view text:first-child{font-size:27rpx;font-weight:900}.enterprise-entry>view text:last-child{color:#dbe8ff;font-size:18rpx;line-height:1.55}.entry-action{padding:15rpx 17rpx;color:#285fbe;background:#fff;border-radius:17rpx;font-size:20rpx;font-weight:800;white-space:nowrap}
.approval-list{display:flex;flex-direction:column;gap:13rpx}.approval-empty{display:flex;flex-direction:column;align-items:center;gap:9rpx;padding:48rpx;color:#8693a7;background:#fff;border:1rpx dashed #d5dde8;border-radius:28rpx}.approval-empty>text{color:#79a4ee;font-size:41rpx}.approval-empty strong{color:#526078;font-size:24rpx}.approval-empty small{font-size:18rpx}.approval-row{display:grid;grid-template-columns:66rpx 1fr auto;align-items:start;gap:15rpx;padding:22rpx;background:#fff;border:1rpx solid #e6ebf2;border-radius:25rpx}.approval-avatar{width:64rpx;height:64rpx;display:flex;align-items:center;justify-content:center;color:#fff;background:#3478f6;border-radius:21rpx;font-weight:800}.approval-row>view:nth-child(2){display:flex;flex-direction:column;gap:6rpx}.approval-row>view:nth-child(2)>text:first-child{font-size:24rpx;font-weight:800}.approval-row small{margin-left:9rpx;padding:4rpx 8rpx;color:#3478f6;background:#edf4ff;border-radius:7rpx;font-size:16rpx}.approval-row>view:nth-child(2)>text:not(:first-child){color:#7e8a9c;font-size:18rpx}.pending-tag{color:#bd7812;font-size:19rpx}.more-entry{width:100%;display:flex;align-items:center;justify-content:space-between;margin-top:14rpx;padding:18rpx 23rpx;color:#3478f6;background:#eef4ff;border:1rpx solid #dce8fb;border-radius:22rpx;text-align:left}.more-entry>view{display:flex;align-items:baseline;gap:13rpx}.more-entry>view text:first-child{font-size:22rpx;font-weight:800}.more-entry>view text:last-child{color:#8195b6;font-size:18rpx}
.members-entry{width:100%;display:grid;grid-template-columns:72rpx 1fr 28rpx;align-items:center;gap:17rpx;margin:0;padding:25rpx;text-align:left}.members-icon{width:70rpx;height:70rpx;display:flex;align-items:center;justify-content:center;color:#805ae0;background:#f1edff;border-radius:22rpx;font-weight:900}.members-entry>view{display:flex;flex-direction:column;gap:7rpx}.members-entry>view text:first-child{font-size:25rpx;font-weight:800}.members-entry>view text:last-child{color:#8793a5;font-size:19rpx}.members-entry>text:last-child{color:#9fa9b7;font-size:36rpx}
.approval-empty-title{color:#526078!important;font-size:24rpx!important;font-weight:800}.approval-empty-copy{font-size:18rpx!important}.approval-type{margin-left:9rpx;padding:4rpx 8rpx;color:#3478f6;background:#edf4ff;border-radius:7rpx;font-size:16rpx}
