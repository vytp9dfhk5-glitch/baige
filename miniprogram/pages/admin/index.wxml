<view class="page-shell admin-page">
  <view class="admin-hero"><text>企业管理</text><text>统一维护企业内容、成员身份、申请状态与名片有效期。</text></view>

  <view class="section-title"><view><text>企业配置</text><text>统一维护名片中的企业内容</text></view></view>
  <button class="enterprise-entry" bindtap="openEnterprise"><text class="entry-icon">⚙</text><view><text>配置企业名片内容</text><text>公司名称、公司地址、公司风采、企业咨询与企业介绍</text></view><text class="entry-action">进入配置 ›</text></button>

  <view class="section-title"><view><text>审批中心</text><text>最新 {{pending.length}} / {{pendingCount}} 条待审核申请</text></view></view>
  <view class="approval-list">
    <view wx:if="{{!pending.length}}" class="approval-empty"><text>♢</text><text class="approval-empty-title">暂无待审核申请</text><text class="approval-empty-copy">职位变更、创建名片或续期申请会显示在这里。</text></view>
    <view wx:for="{{pending}}" wx:key="id" class="approval-row"><view class="approval-avatar">{{item.initial}}</view><view><text>{{item.name || '待完善姓名'}}<text class="approval-type">{{item.typeText}}</text></text><text>{{item.phone}} · {{item.timeText}}</text><text wx:if="{{item.type === 'title_change'}}">{{item.currentTitle}} → {{item.requestedTitle}}</text></view><text class="pending-tag">待审核</text></view>
  </view>
  <button class="more-entry" bindtap="openApprovals"><view><text>更多</text><text>查看全部状态的申请记录</text></view><text>›</text></button>

  <view class="section-title"><view><text>成员与角色</text><text>共 {{memberCount}} 位成员</text></view></view>
  <button class="members-entry section-card" bindtap="openMembers"><text class="members-icon">员</text><view><text>查询与维护成员</text><text>支持模糊搜索、角色配置和登录手机号更新</text></view><text>›</text></button>
</view>
