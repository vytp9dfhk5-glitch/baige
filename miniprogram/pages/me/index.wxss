.me-page{padding-top:25rpx}.account-card{display:flex;align-items:center;gap:24rpx;padding:29rpx;background:linear-gradient(140deg,#fff,#eff5ff)}.account-avatar{width:112rpx;height:112rpx;flex:none;display:flex;align-items:center;justify-content:center;color:#fff;background:linear-gradient(145deg,#6fa6ff,#316fea);border-radius:33rpx;font-size:39rpx;font-weight:900;overflow:hidden}.account-avatar image{width:100%;height:100%}.account-copy{min-width:0;display:flex;flex-direction:column;gap:8rpx}.account-copy text:first-child{font-size:34rpx;font-weight:900}.account-copy text:nth-child(2){color:#7b879a;font-size:21rpx}.account-copy text:last-child{color:#3478f6;font-size:20rpx}.logout-button{width:100%;height:88rpx;margin-top:26rpx;display:flex;align-items:center;justify-content:center;color:#d24f4a;background:#fff;border:1rpx solid #f0d8d7;border-radius:25rpx;font-weight:800}
