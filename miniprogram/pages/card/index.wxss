.card-page{padding-top:12rpx}.card-toolbar{display:flex;align-items:center;justify-content:space-between;margin:0 4rpx 22rpx}.toolbar-title{font-size:39rpx;font-weight:900}.toolbar-actions{display:flex;align-items:center;gap:10rpx}.toolbar-actions button{margin:0}.icon-button{width:70rpx;height:70rpx;position:relative;display:flex;align-items:center;justify-content:center;padding:0;color:#45546b;background:#fff;border:1rpx solid #e5eaf1;border-radius:21rpx;font-size:34rpx}.notice-count{position:absolute;right:-5rpx;top:-6rpx;min-width:28rpx;height:28rpx;padding:0 6rpx;display:flex;align-items:center;justify-content:center;color:#fff;background:#ef5a55;border:3rpx solid #f4f6fa;border-radius:999rpx;font-size:17rpx;font-weight:800}.edit-button,.share-button{height:70rpx;padding:0 22rpx;display:flex;align-items:center;color:#3478f6;background:#edf4ff;border-radius:20rpx;font-size:23rpx;font-weight:800}.share-button{color:#fff;background:#3478f6}.share-button.blocked{opacity:.48}
.status-banner,.renew-banner{display:flex;align-items:center;justify-content:space-between;gap:16rpx;margin-bottom:20rpx;padding:22rpx 24rpx;border-radius:24rpx}.status-banner>view{display:flex;flex-direction:column;gap:6rpx}.status-banner>view>text:first-child{font-size:25rpx;font-weight:800}.status-banner>view>text:last-child{font-size:20rpx;opacity:.8}.status-banner button,.renew-banner button{flex:none;margin:0;padding:12rpx 18rpx;color:inherit;background:#fff;border-radius:15rpx;font-size:21rpx;font-weight:800;line-height:1.2}.banner-pending{color:#a76d10;background:#fff2d8}.banner-expired,.banner-disabled{color:#c74b46;background:#ffedeb}.renew-banner{color:#2861bc;background:#e9f1ff;font-size:22rpx}.renew-banner text:first-child{flex:1}.pending-copy{font-size:21rpx;font-weight:700}
