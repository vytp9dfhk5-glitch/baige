.approval-hero{display:flex;align-items:center;justify-content:space-between;padding:30rpx 34rpx;color:#fff;background:linear-gradient(135deg,#253e78,#3478f6);border-radius:34rpx}.approval-hero>view{display:flex;flex-direction:column;gap:7rpx}.approval-hero>view text:first-child{font-size:37rpx;font-weight:900}.approval-hero>view text:last-child{color:#d4e3ff;font-size:21rpx}.approval-hero strong{font-size:48rpx}.approval-hero small{display:block;font-size:17rpx;font-weight:500}.filter-card{margin:20rpx 0;padding:23rpx}.filter-card>text{display:block;margin:4rpx 0 11rpx;color:#7c899c;font-size:20rpx;font-weight:700}.filter-scroll{width:100%;white-space:nowrap;margin-bottom:17rpx}.filter-scroll>view,.status-filters{display:flex;gap:10rpx}.filter-card button{flex:none;margin:0;padding:11rpx 17rpx;color:#6f7e93;background:#f0f3f7;border-radius:14rpx;font-size:20rpx;line-height:1.3}.filter-card button.active{color:#fff;background:#3478f6}.request-list{display:flex;flex-direction:column;gap:16rpx}.request-card{padding:24rpx}.request-head{display:grid;grid-template-columns:70rpx 1fr auto;gap:15rpx;align-items:start}.request-avatar{width:68rpx;height:68rpx;display:flex;align-items:center;justify-content:center;color:#fff;background:#3478f6;border-radius:22rpx;font-weight:800}.request-head>view{display:flex;flex-direction:column;gap:5rpx}.request-head>view>text:first-child{font-size:25rpx;font-weight:800}.request-head small{margin-left:9rpx;padding:4rpx 8rpx;color:#3478f6;background:#edf4ff;border-radius:8rpx;font-size:16rpx}.request-head>view>text:not(:first-child){color:#8793a5;font-size:18rpx}.request-status{padding:6rpx 11rpx;color:#b77514;background:#fff2dc;border-radius:10rpx;font-size:18rpx}.request-status.approved{color:#168566;background:#e8f8f2}.request-status.rejected{color:#cf504b;background:#ffedeb}.title-change{display:grid;grid-template-columns:1fr 35rpx 1fr;align-items:center;gap:10rpx;margin-top:19rpx;padding:18rpx;background:#f6f8fb;border-radius:18rpx}.title-change>view{display:flex;flex-direction:column;gap:5rpx}.title-change small{color:#8d98a9;font-size:17rpx}.title-change text{font-size:21rpx;font-weight:700}.title-change>text{text-align:center;color:#8d99aa}.request-summary{display:block;margin-top:18rpx;padding:16rpx;color:#65738a;background:#f6f8fb;border-radius:16rpx;font-size:20rpx}.validity-row{display:flex;align-items:center;justify-content:space-between;margin-top:18rpx;padding:15rpx 0;border-top:1rpx solid #edf0f4;font-size:21rpx}.validity-row picker view{padding:11rpx 14rpx;color:#3478f6;background:#edf4ff;border-radius:13rpx}.approval-actions{display:grid;grid-template-columns:1fr 1.5fr;gap:12rpx;margin-top:13rpx}.approval-actions button{margin:0;padding:18rpx;color:#d0524d;background:#fff0ef;border-radius:17rpx;font-size:21rpx;line-height:1.3}.approval-actions button:last-child{color:#fff;background:#3478f6}.rejected-reason{display:block;margin-top:16rpx;padding:15rpx;color:#b24944;background:#fff0ef;border-radius:15rpx;font-size:20rpx;line-height:1.5}
