.visitor-page{padding-top:14rpx}.radar-card{height:236rpx;position:relative;overflow:hidden;padding:36rpx 38rpx;color:#fff;background:linear-gradient(130deg,#1c57c9,#3478f6 65%,#60a1ff);border-radius:38rpx;box-shadow:0 24rpx 46rpx rgba(47,106,230,.22)}.radar-card>view:first-child{position:relative;z-index:2;display:grid;grid-template-columns:auto auto;align-items:end;justify-content:start;gap:0 15rpx}.radar-card>view:first-child>text:first-child{grid-column:span 2;color:#d4e4ff;font-size:23rpx}.radar-card strong{font-size:78rpx;line-height:1.25}.growth{margin-bottom:18rpx;color:#cde1ff;font-size:20rpx}.radar{position:absolute;right:27rpx;top:14rpx;width:210rpx;height:210rpx;display:flex;align-items:center;justify-content:center}.radar>text{position:absolute;border:1rpx solid rgba(255,255,255,.26);border-radius:50%}.radar>text:nth-child(1){width:200rpx;height:200rpx}.radar>text:nth-child(2){width:145rpx;height:145rpx}.radar>text:nth-child(3){width:88rpx;height:88rpx}.radar>view{width:64rpx;height:64rpx;display:flex;align-items:center;justify-content:center;color:#3478f6;background:#fff;border-radius:50%;font-weight:800}
.metric-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14rpx;margin:18rpx 0}.metric-grid>view{padding:22rpx 20rpx;background:#fff;border:1rpx solid #e8edf4;border-radius:27rpx}.metric-grid>view>text{float:right;color:#7da5ed}.metric-grid strong{display:block;font-size:33rpx}.metric-grid small{color:#929cad;font-size:18rpx;white-space:nowrap}.trend-card{padding:28rpx 28rpx 22rpx}.trend-head{display:flex;align-items:center;justify-content:space-between}.trend-head text:first-child{font-size:29rpx;font-weight:800}.trend-head text:last-child{color:#98a2b2;font-size:21rpx}.chart{height:170rpx;display:flex;align-items:flex-end;justify-content:space-around;margin-top:18rpx;background:repeating-linear-gradient(to bottom,#fff 0,#fff 54rpx,#eef1f5 55rpx)}.chart-column{width:12%;height:100%;display:flex;align-items:flex-end;justify-content:center}.chart-bar{width:22rpx;min-height:16rpx;background:linear-gradient(180deg,#65a0ff,#3478f6);border-radius:999rpx 999rpx 4rpx 4rpx}.chart-labels{display:flex;justify-content:space-around;margin-top:9rpx;color:#9ca6b5;font-size:17rpx}.chart-labels text{width:14%;text-align:center}
.visitor-filter{display:flex;align-items:center;justify-content:space-between;margin:25rpx 0 12rpx}.visitor-filter>text{padding:13rpx 22rpx;color:#fff;background:#3478f6;border-radius:17rpx;font-size:21rpx;font-weight:700}.visitor-filter button{margin:0;padding:13rpx 22rpx;color:#66758a;background:#fff;border:1rpx solid #e3e8f0;border-radius:17rpx;font-size:21rpx;line-height:1.3}.visitor-list{overflow:hidden}.visitor-row{display:grid;grid-template-columns:76rpx 1fr auto;align-items:start;gap:18rpx;padding:25rpx 23rpx;border-bottom:1rpx solid #edf0f5}.visitor-row:last-child{border-bottom:0}.visitor-avatar{width:74rpx;height:74rpx;display:flex;align-items:center;justify-content:center;color:#fff;border-radius:25rpx;font-weight:800}.visitor-main>view{display:flex;align-items:center;gap:10rpx}.visitor-main>view>text:first-child{font-size:25rpx;font-weight:800}.visitor-main>text{display:block;margin-top:6rpx;color:#7c899d;font-size:19rpx}.visitor-main>text:last-child{color:#5f6e84}.auth{padding:4rpx 9rpx;color:#7c889a;background:#eef1f5;border-radius:8rpx;font-size:16rpx}.auth.authorized{color:#258568;background:#e8f8f2}.visitor-duration{display:flex;flex-direction:column;align-items:flex-end;gap:6rpx;color:#8c97a8;font-size:17rpx}.visitor-duration strong{color:#3478f6;font-size:21rpx}
.radar-value{font-size:78rpx;font-weight:900;line-height:1.25}.metric-value{display:block;font-size:33rpx;font-weight:900}.metric-label{color:#929cad;font-size:18rpx;white-space:nowrap}.duration-value{color:#3478f6;font-size:21rpx;font-weight:800}
